{
  "name": "piko",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun run build && bun packages/cli/bin/piko",
    "piko": "bun packages/cli/bin/piko",
    "check": "biome check && tsc -b --pretty false",
    "fmt": "biome check --fix",
    "clean": "rm -rf packages/*/dist",
    "build": "bun run fmt && tsc -b",
    "test": "bun test --preload ./packages/host-runtime/test/setup.ts",
    "check:all": "bun run check && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@opentui/core": "^0.3.1",
    "@opentui/solid": "^0.3.1",
    "solid-js": "^1.9.13",
    "yaml": "^2.9.0"
  }
}
