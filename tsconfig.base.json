{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "piko-agent-orchestrator": ["packages/orchestrator/src/index.ts"],
      "piko-engine-protocol": ["packages/engine-protocol/src/index.ts"],
      "piko-engine-native": ["packages/engine-native/src/index.ts"],
      "piko-engine-remote": ["packages/engine-remote/src/index.ts"],
      "piko-orchestrator-protocol": ["packages/orchestrator-protocol/src/index.ts"],
      "piko-orchestrator": ["packages/orchestrator/src/index.ts"],
      "piko-host-runtime": ["packages/host-runtime/src/index.ts"],
      "piko-host-tui": ["packages/host-tui/src/index.ts"]
    },
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "declaration": true,
    "composite": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
